command -v bashlib.sh &> /dev/null || \
{ echo >&2 "$(basename $0): Can't find bashlib.sh.  Aborting."; exit 1; }
. bashlib.sh

EDITOR="${EDITOR:-vi}"
TMPDIR="${TMPDIR:-/tmp}"
FILENAME=$1

if is_available $1 ; then
  FILENAME=$(which $1)
elif [ -z "$1" ] ; then
  FILENAME="$(mktemp ${TMPDIR}/foo.XXXXXXXXX)"
fi

${EDITOR} $FILENAME
